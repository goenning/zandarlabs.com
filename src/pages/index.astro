---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Zandar Labs</title>
    <meta name="description" content="Software Development &amp; Consultancy." />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Zandar Labs" />
    <meta property="og:title" content="Zandar Labs" />
    <meta property="og:type" content="website" />
    <meta property="og:description" content="Software Development &amp; Consultancy." />
    <meta property="og:image" content="https://zandarlabs.com/assets/images/card.jpg" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="800" />
    <meta property="og:url" content="https://zandarlabs.com" />
    <meta property="twitter:card" content="summary_large_image" />

    <link rel="canonical" href="https://zandarlabs.com/" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600&family=Inter:wght@400&display=swap"
    />
  </head>
  <body class="min-h-screen flex items-center justify-center p-16 bg-[#fdfdfd] font-outfit text-[17pt] max-[736px]:p-8 max-[736px]:text-[12pt] max-[480px]:p-4 max-[360px]:p-2 max-[360px]:text-[11pt]">
    <main class="w-full max-w-[50rem]">
      <div class="bg-white rounded-[3rem] border-[3px] border-dashed border-[rgba(74,77,84,0.11)] text-center overflow-hidden">

        <section class="flex flex-col items-center gap-6 p-16 border-b-[3px] border-dashed border-[rgba(74,77,84,0.11)] max-[736px]:py-14 max-[736px]:px-8 max-[360px]:py-[2.625rem] max-[360px]:px-6">
          <img src="/assets/logo.png" alt="Zandar Labs" class="w-44 rounded-[3rem]" />
          <h1 class="text-[#4a4d54] text-[4.25em] font-semibold leading-[1.25] tracking-[-0.05rem] max-[736px]:text-[3.5em]">Zandar Labs</h1>
          <p class="text-[#4a4d54] text-[1em] font-semibold tracking-[0.25rem] uppercase">Ship. Iterate. Repeat.</p>
          <p class="text-[#898b91] text-[1em] leading-[1.875]">We build software that people love to use.</p>
        </section>

        <section class="p-16 border-b-[3px] border-dashed border-[rgba(74,77,84,0.11)] max-[736px]:py-14 max-[736px]:px-8 max-[360px]:py-[2.625rem] max-[360px]:px-6">
          <div class="inline-flex flex-col items-center gap-3 bg-[#f8f9fb] border border-solid border-[rgba(74,77,84,0.1)] rounded-[1.5rem] py-8 px-12 w-full">
            <img src="https://aptakube.com/images/logo.png" alt="Aptakube" class="w-16 h-16 rounded-[1rem] object-contain" />
            <h2 class="text-[#4a4d54] text-[1.5em] font-semibold tracking-[-0.03rem]">Aptakube</h2>
            <p class="text-[#898b91] text-[0.9em] leading-[1.5]">Multi-cluster Kubernetes desktop client</p>
            <a href="https://aptakube.com/" target="_blank" rel="noopener noreferrer" class="inline-block mt-2 text-[#2761f5] text-[0.9em] font-inter no-underline hover:underline">
              aptakube.com
            </a>
          </div>
        </section>

        <section class="p-16 max-[736px]:py-14 max-[736px]:px-8 max-[360px]:py-[2.625rem] max-[360px]:px-6">
          <a href="mailto:hello@zandarlabs.com" class="text-[#2761f5] font-inter text-[1em] underline transition-colors duration-200 hover:text-[#2a08ff] hover:no-underline">Get in touch!</a>
        </section>

        <p class="text-[#898b91] text-[1em] leading-[1.875] px-16 pb-16 max-[736px]:px-8 max-[736px]:pb-14 max-[360px]:px-6 max-[360px]:pb-[2.625rem]">
          Zandar Labs SL is registered in Spain<br />
          <small class="text-[0.8em]">CIF B22969513 · VAT ESB22969513</small>
        </p>

      </div>
    </main>
  </body>
</html>
