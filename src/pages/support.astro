---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>WeightNow Support</title>
    <meta
      name="description"
      content="Support page for WeightNow by Zandar Labs."
    />
    <link rel="canonical" href="https://zandarlabs.com/support" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600&family=Inter:wght@400;500&display=swap"
    />
  </head>
  <body class="min-h-screen p-8 bg-[#fdfdfd] font-outfit text-[16px] text-[#4a4d54] max-[640px]:p-4">
    <main class="mx-auto w-full max-w-3xl">
      <article class="bg-white rounded-4xl border-[3px] border-dashed border-[rgba(74,77,84,0.11)] overflow-hidden">
        <section class="p-10 max-[640px]:p-6 text-center">
          <h1 class="text-[2rem] leading-[1.2] font-semibold tracking-[-0.02rem] max-[640px]:text-[1.6rem]">
            WeightNow Support
          </h1>
          <p class="mt-5 leading-[1.8] font-inter text-[#5c5f66]">
            For any suggestions, help, or feedback, please email
            <a href="mailto:feedback@zandarlabs.com" class="text-[#2761f5] underline hover:no-underline">feedback@zandarlabs.com</a>.
          </p>
          <p class="mt-4 leading-[1.8] font-inter text-[#5c5f66]">
             You can also check out our
             <a href="/weightnow/privacy" class="text-[#2761f5] underline hover:no-underline">Privacy Policy</a>
             for more information about how we handle your data.
          </p>
        </section>
      </article>
    </main>
  </body>
</html>
